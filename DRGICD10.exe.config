<?xml version="1.0"?>
<configuration>
    <configSections>
        <sectionGroup name="userSettings" type="System.Configuration.UserSettingsGroup, System, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089" >
            <section name="S_DRGService.My.MySettings" type="System.Configuration.ClientSettingsSection, System, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089" allowExeDefinition="MachineToLocalUser" requirePermission="false" />
        </sectionGroup>
    </configSections>
    <connectionStrings>
        <add name="DB00" connectionString="Data Source=|DataDirectory|\icd10.sdf;Max Database Size=2048;"
            providerName="Microsoft.SqlServerCe.Client.4.0" />
        <add name="S_DRGService.My.MySettings.icd10ConnectionString"
            connectionString="Data Source=|DataDirectory|\icd10.sdf" providerName="Microsoft.SqlServerCe.Client.4.0" />
    </connectionStrings>
    <system.diagnostics>
        <sources>
            <!-- 這個區段定義 My.Application.Log 的記錄組態-->
            <source name="DefaultSource" switchName="DefaultSwitch">
                <listeners>
                    <add name="FileLog"/>
                    <!-- 取消註解下列區段，以寫入應用程式事件記錄檔-->
                    <!--<add name="EventLog"/>-->
                </listeners>
            </source>
        </sources>
        <switches>
            <add name="DefaultSwitch" value="Information"/>
        </switches>
        <sharedListeners>
            <add name="FileLog" type="Microsoft.VisualBasic.Logging.FileLogTraceListener, Microsoft.VisualBasic, Version=8.0.0.0, Culture=neutral, PublicKeyToken=b03f5f7f11d50a3a, processorArchitecture=MSIL" initializeData="FileLogWriter"/>
            <!-- 取消註解下列區段，並將 APPLICATION_NAME 取代成您的應用程式名稱，以寫入至應用程式事件記錄檔-->
            <!--<add name="EventLog" type="System.Diagnostics.EventLogTraceListener" initializeData="APPLICATION_NAME"/> -->
        </sharedListeners>
    </system.diagnostics>
  <startup><supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.0,Profile=Client"/></startup>
  <appSettings>
    <!--SQL CE-->
    <add key="DB00" value="Data Source=|DataDirectory|\icd10.sdf;Password=;Persist Security Info=True;Max Database Size=2048;" />
    <add key="dbtype" value="sqlce"/>
    <!--Oracle-->
    <!--<add key="DB00" value="Data Source=(DESCRIPTION = (ADDRESS_LIST = (ADDRESS = (PROTOCOL = TCP)(HOST = xxx.xxx.xxx.xxx)(PORT = xxx))) (CONNECT_DATA = (SID = xxx)));User ID=xxx;Password=xxx" />
    <add key="dbtype" value="oracle"/>-->
    <!--SQL Server-->
    <!--<add key="DB00" value="Data Source=xxx.xxx.xxx.xxx;database=xxx;User ID=xxx;Password=xxx;" />-->
    <!--<add key="dbtype" value="sqlserver"/>-->
  </appSettings>
  <userSettings>
    <S_DRGService.My.MySettings>
      <setting name="DoOnce" serializeAs="String">
        <value>False</value>
      </setting>
    </S_DRGService.My.MySettings>
  </userSettings>
</configuration>
